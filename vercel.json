{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "npm install",
  "buildCommand": "",
  "outputDirectory": "",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "telvoice.cl" }],
      "destination": "https://www.telvoice.cl/:path*",
      "permanent": true
    }
  ],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30
    }
  }
}
