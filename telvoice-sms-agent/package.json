{
  "name": "telvoice-sms-agent",
  "version": "1.0.0",
  "description": "Agente backend Telvoice para envío de SMS vía API aSMSC/Telvoice",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && npm run build:app-css",
    "build:app-css": "tsx scripts/build-app-panel-css.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "setup:env": "tsx scripts/setup-env.ts",
    "setup:env:force": "tsx scripts/setup-env.ts --force",
    "verify:setup": "tsx scripts/verify-setup.ts",
    "verify:agent-core": "tsx scripts/verify-agent-core.ts",
    "test:agent-persona": "tsx scripts/test-agent-persona.ts",
    "test:panel-agent-session": "node scripts/test-panel-agent-session.mjs",
    "migrate:agent-core": "node scripts/apply-migrations-agent-core.mjs",
    "debug:supabase": "tsx scripts/debug-supabase.ts",
    "debug:supabase-rest": "tsx scripts/debug-supabase-rest.ts",
    "seed:admin": "tsx scripts/seed-admin.ts",
    "seed:sms-routing": "node scripts/seed-sms-routing.mjs",
    "seed:chile-3-providers": "node scripts/seed-chile-3-providers.mjs",
    "migrate:017": "node scripts/apply-migration-017.mjs",
    "migrate:021": "node scripts/apply-migration-021.mjs",
    "migrate:026": "node scripts/apply-migration-026.mjs",
    "migrate:027": "node scripts/apply-migration-027.mjs",
    "migrate:028": "node scripts/apply-migration-028.mjs",
    "migrate:033": "node scripts/apply-migration-033.mjs",
    "migrate:034": "node scripts/apply-migration-034.mjs",
    "migrate:035": "node scripts/apply-migration-035.mjs",
    "migrate:036": "node scripts/apply-migration-036.mjs",
    "migrate:037": "node scripts/apply-migration-037.mjs",
    "migrate:038": "node scripts/apply-migration-038.mjs",
    "migrate:025": "node scripts/apply-migration-025.mjs",
    "seed:scheduler-test13": "node scripts/seed-scheduler-test13.mjs",
    "seed:scheduler-load5": "node scripts/seed-scheduler-load5.mjs",
    "migrate:telsim": "node scripts/apply-migration-telsim.mjs",
    "telegram:get-me": "tsx scripts/telegram-get-me.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.8",
    "axios": "^1.9.0",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "pdfkit": "^0.18.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.21",
    "@types/pdfkit": "^0.17.6",
    "@types/uuid": "^10.0.0",
    "pg": "^8.16.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
