ASMSC_BASE_URL=http://api.telvoice.net/api
ASMSC_API_ID=
ASMSC_API_PASSWORD=
ASMSC_DEFAULT_SENDER_ID=
ASMSC_DEFAULT_SMS_TYPE=P
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_MODE=polling
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_PATH=/api/telegram/webhook
PUBLIC_WEBHOOK_BASE_URL=https://agent.telvoice.cl
PUBLIC_APP_URL=https://agent.telvoice.cl
PUBLIC_SITE_URL=https://www.telvoice.cl
# MercadoPago — mismas credenciales que telvoice.cl (landing en Vercel + panel /app en agent)
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_SANDBOX=true
MERCADOPAGO_TEST_PAYER_EMAIL=
# Opcional: URLs de retorno del panel /app (default PUBLIC_APP_URL + /app/payments/mercadopago/...)
# MERCADOPAGO_SUCCESS_URL_APP=
# MERCADOPAGO_FAILURE_URL_APP=
# MERCADOPAGO_PENDING_URL_APP=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
ENCRYPTION_KEY=
PORT=3001
NODE_ENV=development

# SMS panel — mock / live_test controlado (https://agent.telvoice.cl/app/send-sms)
SMS_PROVIDER_MODE=mock
SMS_PROVIDER=real_api
SMS_LIVE_TEST_ENABLED=false
SMS_LIVE_TEST_ALLOWED_COMPANY_IDS=
SMS_LIVE_TEST_ALLOWED_NUMBERS=
SMS_LIVE_TEST_DAILY_LIMIT=3
SMS_LIVE_TEST_MIN_SECONDS_BETWEEN_SENDS=60
SMS_LIVE_TEST_MAX_SEGMENTS=1

# Panel administrativo (https://agent.telvoice.cl/admin)
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=
SUPERADMIN_NAME=Telvoice Superadmin
JWT_SECRET=
SESSION_SECRET=
# Registro en /admin/register con @gmail.com (también se abre si no hay ningún admin en BD)
ADMIN_SIGNUP_ENABLED=false
