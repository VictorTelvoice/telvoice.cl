ASMSC_BASE_URL=http://api.telvoice.net/api
ASMSC_API_ID=
ASMSC_API_PASSWORD=
ASMSC_DEFAULT_SENDER_ID=
ASMSC_DEFAULT_SMS_TYPE=P
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_MODE=polling
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_PATH=/api/telegram/webhook
PUBLIC_WEBHOOK_BASE_URL=https://agent.telvoice.cl
PUBLIC_APP_URL=https://agent.telvoice.cl
PUBLIC_SITE_URL=https://www.telvoice.cl
# MercadoPago — mismas credenciales que telvoice.cl (landing en Vercel + panel /app en agent)
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_SANDBOX=true
MERCADOPAGO_TEST_PAYER_EMAIL=
# Opcional: URLs de retorno del panel /app (default PUBLIC_APP_URL + /app/payments/mercadopago/...)
# MERCADOPAGO_SUCCESS_URL_APP=
# MERCADOPAGO_FAILURE_URL_APP=
# MERCADOPAGO_PENDING_URL_APP=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Login Google (/login) — solo clave anon/publishable en el navegador (nunca service_role)
# VITE_* se leen al arrancar el proceso Node (dotenv), no en un build Vite separado.
VITE_SUPABASE_URL=
# Si VITE_SUPABASE_URL está vacío, el servidor usa SUPABASE_URL como fallback.
VITE_SUPABASE_PUBLISHABLE_KEY=
ENCRYPTION_KEY=
PORT=3001
NODE_ENV=development

# SMS panel — envío real (/app/send-sms)
SMS_PROVIDER_MODE=live_test
SMS_PROVIDER=real_api
SMS_LIVE_TEST_ENABLED=true
# Opcional: restringir empresas/números (vacío = todos con live_enabled)
SMS_LIVE_TEST_ALLOWED_COMPANY_IDS=
SMS_LIVE_TEST_ALLOWED_NUMBERS=
SMS_LIVE_TEST_DAILY_LIMIT=10000
# false = panel /app sin tope diario (solo saldo SMS). true = aplica límite env + política telco.
SMS_ENFORCE_DAILY_LIMIT=false
SMS_LIVE_TEST_MIN_SECONDS_BETWEEN_SENDS=5
SMS_LIVE_TEST_MAX_SEGMENTS=3

# Campañas masivas (planilla → cola → proveedor)
SMS_CAMPAIGN_ENABLED=true
SMS_CAMPAIGN_SKIP_NUMBER_WHITELIST=true
SMS_CAMPAIGN_BULK_QUEUE_MIN_RECIPIENTS=1
SMS_CAMPAIGN_TRAFFIC_TYPE=promotional
# Separación entre destinatarios en cola (s); Test12/13 ~3s entre envíos aSMSC
SMS_CAMPAIGN_QUEUE_MIN_PACE_SECONDS=3
# Campañas live desde borrador de contactos (Etapa 7)
SMS_LIVE_CAMPAIGN_MAX_RECIPIENTS=50
SMS_LIVE_CAMPAIGN_MAX_SEGMENTS=3
SMS_PLATFORM_MAX_TPS=100

# Cola — 20 SMS/s: intervalo 1s y batch 20 (alinear con max_tps del cliente)
SMS_QUEUE_SCHEDULER_ENABLED=true
SMS_QUEUE_SCHEDULER_INTERVAL_SECONDS=1
SMS_QUEUE_SCHEDULER_BATCH_SIZE=20

# Números telsim.io para QA pre-campaña (formato: +569xxx:Etiqueta:Operador:slot_id|...)
# slot_id = ID del slot SIM en telsim.io (para enlazar SMS entrantes del webhook)
# Ejemplo: +56912345678:Linea 1 telsim:Movistar:abc-slot-id|+56987654321:Linea 2:Entel:def-slot-id
# Ejemplo producción QA telsim (añade :slot_id como 4º segmento cuando lo tengas en telsim.io)
TELVOICE_VERIFY_NUMBERS=+56934449937:Entel:Entel|+56974713166:Movistar 1:Movistar|+56977109623:Movistar 2:Movistar

# Webhook entrante telsim.io (sms.received) — firma HMAC con este secret
PUBLIC_WEBHOOK_BASE_URL=https://agent.telvoice.cl
TELSIM_WEBHOOK_SECRET=
# Solo desarrollo local (nunca en producción):
# TELSIM_WEBHOOK_SKIP_VERIFY=true

# Emails transaccionales (activación claim, bienvenida, etc.)
# mock = solo registra email_logs, no envía correo real
EMAIL_MODE=mock
EMAIL_FROM_NAME=Telvoice
EMAIL_FROM_ADDRESS=no-reply@telvoice.cl
EMAIL_REPLY_TO=soporte@telvoice.cl

# Billing — comprobantes por email (Etapa 12.5+)
# mock = solo registra billing_email_logs, no envía correo real
BILLING_EMAIL_MODE=mock
# BILLING_EMAIL_FROM=facturacion@telvoice.cl
# BILLING_EMAIL_PROVIDER=
# BILLING_EMAIL_REPLY_TO=soporte@telvoice.cl

# Panel administrativo (https://agent.telvoice.cl/admin)
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=
SUPERADMIN_NAME=Telvoice Superadmin
JWT_SECRET=
SESSION_SECRET=
# Registro en /admin/register con @gmail.com (también se abre si no hay ningún admin en BD)
ADMIN_SIGNUP_ENABLED=false
