# Copiar a /var/www/telvoice-sms-agent-sim-qa/.env — NUNCA commitear con valores reales.
# Instancia: telvoice-sms-agent-sim-qa (PM2, puerto 3002)

PORT=3002
NODE_ENV=production

# URLs QA — NO producción
PUBLIC_APP_URL=https://agent-qa.telvoice.cl
PUBLIC_WEBHOOK_BASE_URL=https://agent-qa.telvoice.cl
# Preview Vercel numeracion-sim (no www.telvoice.cl)
PUBLIC_SITE_URL=https://telvoice-3983qthzr-victor-9928s-projects.vercel.app
SIM_QA_E2E_INVENTORY_QA_ONLY=true
LANDING_EXTRA_ORIGINS=https://telvoice-3983qthzr-victor-9928s-projects.vercel.app

# MercadoPago SANDBOX únicamente (pestaña Prueba en developers.mercadopago.com)
MERCADOPAGO_SANDBOX=true
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_TEST_PAYER_EMAIL=

# Misma Supabase que prod (datos QA marcados en metadata) — no tocar wallet productivo en scripts
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Opcional: SHA deploy QA
GIT_COMMIT_SHA=
