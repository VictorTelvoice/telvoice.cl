# Mercado Pago (solo servidor — nunca en frontend)
#
# SANDBOX (pruebas):
#   MERCADOPAGO_SANDBOX=true
#   MERCADOPAGO_ACCESS_TOKEN = Access Token de la pestaña "Prueba" (suele empezar con TEST-)
#   MERCADOPAGO_PUBLIC_KEY   = Public Key de la pestaña "Prueba" (TEST-...)
#   Al pagar: ventana de incógnito, NO iniciar sesión con tu cuenta real de Mercado Pago.
#   Tarjeta Visa prueba: 4168 8188 4444 7115 · CVV 123 · venc. 11/30 · titular: APRO
#
# PRODUCCIÓN (cobros reales):
#   MERCADOPAGO_SANDBOX=false
#   MERCADOPAGO_ACCESS_TOKEN = Access Token de la pestaña "Producción"
#   MERCADOPAGO_PUBLIC_KEY   = Public Key de Producción (APP_USR-...)
#
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_WEBHOOK_SECRET=
MERCADOPAGO_SANDBOX=true

# Sitio público (URLs de retorno y webhook)
PUBLIC_SITE_URL=https://www.telvoice.cl

# Persistencia de órdenes (Vercel Blob — requerido en producción)
BLOB_READ_WRITE_TOKEN=
